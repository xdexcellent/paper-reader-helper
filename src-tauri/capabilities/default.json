{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capability for the main window — allows spawning the backend sidecar and running uv in dev mode",
  "windows": ["main"],
  "permissions": [
    "core:default",
    {
      "identifier": "shell:allow-spawn",
      "allow": [
        {
          "name": "binaries/backend",
          "sidecar": true,
          "args": true
        },
        {
          "name": "uv-dev-backend",
          "sidecar": false,
          "cmd": "uv",
          "args": [
            "run",
            "--directory",
            { "validator": "\\S+" },
            "uvicorn",
            { "validator": "\\S+\\.\\S+:\\S+" },
            "--host",
            "0.0.0.0",
            "--port",
            { "validator": "\\d+" },
            "--reload"
          ]
        }
      ]
    },
    "shell:allow-kill"
  ]
}