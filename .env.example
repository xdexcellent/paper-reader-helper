MINERU_API_BASE=https://mineru.net
MINERU_API_TOKEN=
DEEPSEEK_API_BASE=https://api.deepseek.com
DEEPSEEK_API_KEY=

# Database URL — leave empty for mode-appropriate default:
#   Source mode (default): sqlite:///./data/paper_reader.db
#   Desktop mode: sqlite:///%APPDATA%/paper-reader/data/paper_reader.db
DATABASE_URL=

# Storage root — leave empty for mode-appropriate default:
#   Source mode (default): ./data/storage
#   Desktop mode: %APPDATA%/paper-reader/data/storage
STORAGE_ROOT=

SERVER_BASE_URL=http://localhost:8000

# CORS origins — comma-separated
# Default for dev: http://localhost:3000
# Desktop mode uses same-origin (no CORS needed)
CORS_ORIGINS=http://localhost:3000

APP_PASSWORD=
JWT_SECRET=change-this-to-a-long-random-value
EMBEDDING_MODEL_PATH=BAAI/bge-m3

# Desktop / production mode settings
# Set DESKTOP_MODE=true to enable desktop-friendly paths and static file serving
DESKTOP_MODE=false

# Static directory for serving frontend files in production mode
# Set to frontend/dist path when running uvicorn standalone (no Vite dev server)
# Example: STATIC_DIR=../frontend/dist
STATIC_DIR=
